# Ollama Cloud API
OPENAI_BASE_URL=base_url # Use openai compatible api https://openrouter.ai/api/v1
OPENAI_API_KEY=api_key_here
OPENAI_TEMPERATURE=0.7

# Per-route model assignments (must be available on Ollama cloud)
OPENAI_MODEL_CLASSIFY=stepfun/step-3.5-flash:free
OPENAI_MODEL_SENTIMENT=z-ai/glm-4.5-air:free
OPENAI_MODEL_SUMMARIZE=nvidia/nemotron-3-super-120b-a12b:free
OPENAI_MODEL_INTENT=arcee-ai/trinity-large-preview:free

# Server
SERVER_PORT=8082